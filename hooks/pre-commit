#!/bin/bash

GREEN='\033[0;32m'
RED='\033[0;31m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

UNSTAGED_CHANGES=$(git diff --name-only $STAGED_FILES)
if [ -n "$UNSTAGED_CHANGES" ]; then
    echo -e "${RED}Error: You have unstaged changes in staged files.${NC}"
    echo "Please stage all changes in these files or stash them before committing."
    exit 1
fi

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
if [ -z "$STAGED_FILES" ]; then
    echo -e "${RED}Error: No staged files to commit.${NC}"
    exit 1
fi

LOG_FILE=$(mktemp)

echo -e "${BLUE}▶ Starting Pre-Commit Quality Checks...${NC}"

# Automatic Formatting (Spotless)
echo -ne "  [1/3] Running Formatter (Spotless)... "

    # Run spotless on the whole project (Maven limitation)
    mvn spotless:apply > "$LOG_FILE" 2>&1

    if [ $? -eq 0 ]; then
        echo -e "${GREEN}FIXED/OK${NC}"

        # 2. Re-stage ONLY the files that were originally staged
        for FILE in $STAGED_FILES; do
            if [ -f "$FILE" ]; then
                git add "$FILE"
            fi
        done
    else
        echo -e "${RED}FAILED${NC}"
        echo -e "${YELLOW}--- SPOTLESS ERROR LOG ---${NC}"
        cat "$LOG_FILE"
        rm -f "$LOG_FILE"
        exit 1
    fi

# Linting (Checkstyle)
echo -ne "  [2/3] Running Linter (Checkstyle)... "
mvn checkstyle:check > "$LOG_FILE" 2>&1
if [ $? -eq 0 ]; then
    echo -e "${GREEN}PASSED${NC}"
else
    echo -e "${RED}FAILED${NC}"
    echo -e "${YELLOW}--- CHECKSTYLE VIOLATIONS ---${NC}"
    grep "\[ERROR\]" "$LOG_FILE" || cat "$LOG_FILE"
    rm -f "$LOG_FILE"
    exit 1
fi

# Unit Tests (Surefire)
echo -ne "  [3/3] Running Tests (Surefire)... "
mvn test > "$LOG_FILE" 2>&1
if [ $? -eq 0 ]; then
    echo -e "${GREEN}PASSED${NC}"
else
    echo -e "${RED}FAILED${NC}"
    echo -e "${YELLOW}--- TEST FAILURE SUMMARY ---${NC}"
    grep -A 5 "Failed tests:" "$LOG_FILE" || cat "$LOG_FILE"
    rm -f "$LOG_FILE"
    exit 1
fi

rm -f "$LOG_FILE"

echo -e "${GREEN}✔ All checks passed! Proceeding with commit.${NC}"
exit 0